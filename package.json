{
  "name": "sipher",
  "version": "0.1.0",
  "description": "Privacy-as-a-Skill REST API for Solana Agents — powered by SIP Protocol",
  "author": "SIP Protocol <hello@sip-protocol.org>",
  "homepage": "https://sipher.sip-protocol.org",
  "repository": {
    "type": "git",
    "url": "https://github.com/sip-protocol/sipher.git"
  },
  "main": "./dist/server.js",
  "type": "module",
  "scripts": {
    "start": "node dist/server.js",
    "dev": "tsup --watch src --onSuccess 'node dist/server.js'",
    "build": "tsup",
    "test": "vitest",
    "typecheck": "pnpm typecheck:root && pnpm -r --filter='!sipher' run typecheck",
    "typecheck:root": "tsc --noEmit",
    "lint": "eslint",
    "clean": "rm -rf dist",
    "colosseum": "tsx scripts/colosseum.ts",
    "demo": "tsx scripts/demo-flow.ts",
    "multi-agent": "tsx scripts/multi-agent-demo.ts",
    "benchmark": "tsx scripts/benchmark.ts",
    "gm": "bash scripts/gm.sh",
    "thanks": "bash scripts/thanks.sh",
    "openapi:export": "tsx scripts/export-openapi.ts",
    "preflight:torque": "bash scripts/torque-preflight.sh",
    "sdks:generate": "bash sdks/generator/generate.sh",
    "devnet-demo": "tsx scripts/devnet-shielded-transfer.ts",
    "test:e2e": "playwright test",
    "test:e2e:ui": "playwright test --ui",
    "test:e2e:headed": "playwright test --headed"
  },
  "dependencies": {
    "@anthropic-ai/claude-agent-sdk": "^0.3.185",
    "@noble/curves": "^1.8.2",
    "@noble/hashes": "^2.2.0",
    "@sip-protocol/sdk": "^0.11.0",
    "@sip-protocol/types": "^0.2.2",
    "@solana/spl-token": "^0.4.0",
    "@solana/web3.js": "^1.95.0",
    "bs58": "^6.0.0",
    "compression": "^1.8.1",
    "cors": "^2.8.5",
    "envalid": "^8.2.0",
    "express": "^5.1.0",
    "express-rate-limit": "^8.5.2",
    "helmet": "^8.2.0",
    "ioredis": "^5.11.1",
    "lru-cache": "^11.5.1",
    "pino": "^10.0.0",
    "pino-http": "^11.0.0",
    "swagger-ui-express": "^5.0.1",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@playwright/test": "^1.61.0",
    "@sipher/sdk": "workspace:*",
    "@types/compression": "^1.8.1",
    "@types/cors": "^2.8.17",
    "@types/express": "^5.0.0",
    "@types/ioredis": "^5.0.0",
    "@types/node": "^26.0.1",
    "@types/supertest": "^7.2.0",
    "@types/swagger-ui-express": "^4.1.8",
    "@typescript-eslint/parser": "^8.61.1",
    "eslint": "^10.5.0",
    "pino-pretty": "^13.0.0",
    "supertest": "^7.1.0",
    "tsup": "^8.3.6",
    "tsx": "^4.22.4",
    "typescript": "^5.7.3",
    "typescript-eslint": "^8.61.1",
    "vitest": "^4.1.9"
  },
  "keywords": [
    "sip",
    "privacy",
    "solana",
    "stealth-addresses",
    "agents",
    "openclaw",
    "rest-api"
  ],
  "license": "MIT",
  "pnpm": {
    "onlyBuiltDependencies": [
      "better-sqlite3",
      "bufferutil",
      "utf-8-validate"
    ]
  }
}
