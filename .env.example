# Server
NODE_ENV=development
PORT=5006
LOG_LEVEL=info

# Authentication
API_KEYS=dev-key-1,dev-key-2
ADMIN_API_KEY=

# Command Center UI admin login (password-based).
# Empty = admin login disabled (fail-closed). Generate: openssl rand -base64 24
SIPHER_ADMIN_PASSWORD=

# JWT signing secret for Command Center auth tokens. REQUIRED >= 16 chars.
# Runtime throws if unset or too short. Generate: openssl rand -hex 32
JWT_SECRET=

# Admin wallet allowlist (comma-separated base58 pubkeys)
AUTHORIZED_WALLETS=

# Sipher Agent (OpenRouter)
SIPHER_OPENROUTER_API_KEY=
OPENROUTER_API_KEY=
SIPHER_MODEL=anthropic/claude-sonnet-4.6

# Sipher public URL (used for payment links, invoices)
SIPHER_BASE_URL=https://sipher.sip-protocol.org

# Solana
SOLANA_NETWORK=mainnet-beta
SOLANA_RPC_URL=https://api.mainnet-beta.solana.com
SOLANA_RPC_URL_FALLBACK=
RPC_PROVIDER=generic
RPC_PROVIDER_API_KEY=

# Helius (dedicated key — used when RPC_PROVIDER=helius and RPC_PROVIDER_API_KEY is empty)
SIPHER_HELIUS_API_KEY=

# Redis (optional — falls back to in-memory LRU)
REDIS_URL=

# Jupiter DEX API (defaults to free tier)
JUPITER_API_URL=https://lite-api.jup.ag

# Jito Block Engine (required for real bundle relay — mock mode when empty)
# Production: https://mainnet.block-engine.jito.wtf/api/v1/bundles
JITO_BLOCK_ENGINE_URL=

# Stripe (billing webhooks)
STRIPE_WEBHOOK_SECRET=

# CORS
CORS_ORIGINS=http://localhost:3000,http://localhost:5173

# Rate Limiting
RATE_LIMIT_MAX=100
RATE_LIMIT_WINDOW_MS=60000

# Proxy
TRUST_PROXY=1

# Graceful Shutdown
SHUTDOWN_TIMEOUT_MS=30000

# ───────────────────────────────────────────
# SENTINEL Security Agent (see docs/deployment.md)
# ───────────────────────────────────────────
# Autonomy mode: yolo (full autonomy) | advisory (recommend only) | off (rule-based only)
# Code defaults to 'yolo' when unset; we ship 'advisory' here as a safer first-deploy default.
# Promote to 'yolo' only after >= 1 week of advisory-mode observation (see docs/deployment.md).
SENTINEL_MODE=advisory

# Path to vault authority keypair JSON. Required for auto-refunds.
# Empty = refund attempts throw at runtime (caught by circuit breaker).
SENTINEL_AUTHORITY_KEYPAIR=
